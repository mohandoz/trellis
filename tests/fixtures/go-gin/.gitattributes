* text=auto eol=lf

# Force LF for shell + config
*.sh           text eol=lf
*.bash         text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf

# Windows-only scripts
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf

# Binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.pdf          binary
*.zip          binary
*.tar          binary
*.tar.gz       binary
*.parquet      binary
*.h5           binary
*.pkl          binary

# Generated — diff hidden by default
*.lock         linguist-generated=true
*-lock.json    linguist-generated=true
*.min.js       linguist-generated=true
*.min.css      linguist-generated=true
