root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{py,java,kt,scala}]
indent_size = 4

[*.go]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # markdown line-break uses trailing spaces

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
